# Classic Mini DIY — environment variables
#
# Copy to `.env` and fill in your own values. NEVER commit `.env`.
# Names only here — no real values belong in this file, ever.
# Optional vars degrade gracefully when unset (noted inline).

# --- AWS (DynamoDB legacy data + S3 archive assets) ---
dynamo_id=
dynamo_key=
s3_id=
s3_key=
s3Base=

# --- External APIs ---
githubAPIKey=
youtubeAPIKey=
validation_key=

# --- AI chat (LangGraph proxy — server-only key) ---
NUXT_LANGGRAPH_API_URL=
NUXT_LANGSMITH_API_KEY=

# --- Nuxt Content database ---
POSTGRES_URL=

# --- Supabase (shared CMDIY auth/profiles/marketplace) ---
NUXT_PUBLIC_SUPABASE_URL=
NUXT_PUBLIC_SUPABASE_KEY=
# Server-only. Never expose to the client or put in runtimeConfig.public.
SUPABASE_SERVICE_KEY=

# --- Site ---
NUXT_PUBLIC_SITE_URL=http://localhost:3000
NUXT_PUBLIC_BLOG_URL=

# --- MCP server auth (fails closed: unset = every request rejected) ---
MCP_API_KEY=
MCP_API_KEYS=

# --- Analytics (public key by design) ---
POSTHOG_PUBLIC_KEY=
# POSTHOG_HOST defaults to https://us.i.posthog.com

# --- Login (Cloudflare Turnstile) ---
NUXT_PUBLIC_TURNSTILE_SITE_KEY=
NUXT_TURNSTILE_SECRET_KEY=

# --- 3D Model Library (dedicated bucket + IAM user) ---
S3_MODELS_BUCKET=
S3_MODELS_REGION=
S3_MODELS_ACCESS_KEY_ID=
S3_MODELS_SECRET_ACCESS_KEY=
# Optional: Microlink pro tier for the external-model scraper fallback
MICROLINK_API_KEY=

# --- The Mini Exchange marketplace ---
# Cutover flag: routes 404 everywhere until true
NUXT_PUBLIC_EXCHANGE_ENABLED=false
# Optional: safe-meeting-spot + distance proxies (502 gracefully when unset)
CAMINO_API_KEY=
# Optional: web push (UI hidden when unset)
NUXT_PUBLIC_VAPID_PUBLIC_KEY=
# Optional: listing map display
NUXT_PUBLIC_MAPBOX_ACCESS_TOKEN=
# Optional: membership manage link on /membership
NUXT_PUBLIC_STRIPE_PORTAL_URL=

# --- Rate limit tuning (defaults are sane; override only if needed) ---
# LANGGRAPH_RATELIMIT_MAX=40
# LANGGRAPH_RATELIMIT_WINDOW_MS=60000
# WRITE_RATELIMIT_MAX=
# WRITE_RATELIMIT_WINDOW_MS=
